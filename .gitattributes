# Auto-detect text files
* text=auto

# Markdown
*.md text diff=markdown

# CSV
*.csv text diff=csv

# Python
*.py text diff=python

# HTML
*.html text diff=html

# JSON
*.json text

# YAML
*.yml text
*.yaml text

# Shell / PowerShell scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
